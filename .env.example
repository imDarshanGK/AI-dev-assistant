# QyverixAI environment example
# Copy values into your platform secret manager; do not commit real secrets.

# Core app
AI_PROVIDER=rule-based
AI_MODEL=local-rule-engine-v1
ENABLE_DOCS=false
PUBLIC_ROOT_INFO=false

# Request safety and limits
MAX_CODE_CHARS=20000
MAX_REQUEST_BYTES=1048576
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# Cache and error tracking
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
REDIS_URL=
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Database and auth
DATABASE_URL=sqlite:///./assistant.db
JWT_SECRET=change-this-in-production-min-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=720

# Optional live LLM (OpenAI-compatible)
LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30
